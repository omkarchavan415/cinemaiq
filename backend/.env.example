# CinemaIQ Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Get from: https://www.mongodb.com/atlas (free tier available)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cinemaiq?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# ─── TMDB API ──────────────────────────────────────────────────────────────────
# Get from: https://www.themoviedb.org/settings/api (free)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
